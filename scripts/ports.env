# Shared host-side port configuration for both local Podman stacks under this scripts\ folder -
# scripts\local-kafka\setup-podman-kafka.bat and scripts\local-emulators\setup-podman-emulators.bat.
# Edit a value here (then re-run the relevant setup script) if one of these already-in-use on your
# machine conflicts with something else - the container-internal ports these map to are fixed by
# the images/scripts themselves and are not affected by this file.
#
# KEY=VALUE, one per line, no quotes/spaces around '='. Lines starting with '#' are comments.
# Changing a value here does NOT update appsettings.Development.json or your user-secrets - if you
# move a port away from its default, update whatever references it to match (Kafka:BootstrapServers/
# SchemaRegistryUrl, CosmosDb:AccountEndpoint/DataExplorer, ServiceBus:ConnectionString,
# BlobStorage:Hot/Cold:AccountUri, etc.), or the app will keep pointing at the old port. See
# local-kafka\README.md and local-emulators\README.md's "Configuring ports" sections.

# --- scripts\local-kafka\setup-podman-kafka.bat ---

# Kafka broker - the SASL_PLAINTEXT_HOST listener the app/CLI tools connect to
# (Kafka:BootstrapServers). Also folded into KAFKA_ADVERTISED_LISTENERS so a client's post-connect
# metadata reconnect address matches this same port, not just the -p mapping.
KAFKA_BROKER_PORT=9092

# Schema Registry - its HTTP Basic Auth REST API (Kafka:SchemaRegistryUrl).
SCHEMA_REGISTRY_PORT=8085

# Kafka UI web console.
KAFKA_UI_PORT=8090

# Kafka REST Proxy - produce messages via curl (see local-kafka\README.md "Push a message via curl").
KAFKA_REST_PORT=8086

# events-api.ps1 wrapper - the interactive Postman/curl testing endpoint setup-podman-kafka.bat
# starts in the foreground as its last step.
EVENTS_API_PORT=8087

# Local stack summary dashboard - the small container (dashboard-server.ps1) setup-podman-kafka.bat
# starts to serve generate-local-stack-summary.ps1's generated HTML as http://localhost instead of
# file://, so its refresh (&#x21bb;) buttons work (see that script's own header comment for why).
DASHBOARD_PORT=8098

# --- scripts\local-emulators\setup-podman-emulators.bat ---

# Cosmos DB Emulator - the account endpoint the Microsoft.Azure.Cosmos SDK talks to
# (CosmosDb:AccountEndpoint).
COSMOS_ENDPOINT_PORT=8081

# Cosmos DB Emulator - its own health-probe endpoint (/alive, /ready, /status), polled by that
# script's own wait loop. Not something the app itself calls.
COSMOS_HEALTH_PORT=8080

# Cosmos DB Emulator - the bundled Data Explorer web UI (CosmosDb:DataExplorer).
COSMOS_EXPLORER_PORT=1234

# Service Bus emulator - the AMQP endpoint ServiceBusClient connects to (part of
# ServiceBus:ConnectionString's Endpoint=sb://localhost;... value).
SERVICEBUS_AMQP_PORT=5672

# Service Bus emulator - its management/health HTTP API, polled by that script's own wait loop and
# needed by ServiceBusAdministrationClient (appended explicitly to the connection string's
# Endpoint, e.g. sb://localhost:5300;...).
SERVICEBUS_MGMT_PORT=5300

# Azurite - the Blob Storage endpoint (BlobStorage:Hot/Cold:AccountUri's BlobEndpoint, folded into
# the "UseDevelopmentStorage=true" shorthand at this default). Also Azurite's own well-known
# account/key, matching devstoreaccount1 - not something you'd remap independently of the port.
AZURITE_BLOB_PORT=10000

# Azurite - the Table Storage endpoint. Nothing in this codebase uses Table Storage yet (see
# local-emulators\README.md's Azurite section) - this only matters once something does.
AZURITE_TABLE_PORT=10002

# rclone web UI - the interactive Blob browser (browse/upload/download/delete/rename) for Azurite's
# accounts, since Azurite itself has no built-in web UI. See local-emulators\README.md's "Interactive
# web UI (rclone)" section.
RCLONE_UI_PORT=5572
