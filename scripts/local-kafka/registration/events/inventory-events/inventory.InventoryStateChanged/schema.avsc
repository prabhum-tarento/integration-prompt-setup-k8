								"UNKNOWN",
								"AVAILABLE",
								"BLOCKED",
								"INSPECTION",
								"SCRAP",
								"REWORK",
								"REMELT",
								"STONE",
								"AVAILABLETOSELL"
							],
							"default": "UNKNOWN"
						},
						"doc": "State of inventory in a location"
					},
					{
						"name": "status",
						"type": {
							"type": "enum",
							"name": "Status",
							"doc": "Status of inventory in a location",
							"symbols": [
								"UNKNOWN",
								"PICKABLE",
								"HELD",
								"PREPARED",
								"HALLMARKING",
								"ALLOCATED",
								"INVOICED"
							],
							"default": "UNKNOWN"
						},
						"doc": "Status of inventory in a location"
					}
				]
			},
			"doc": "The state from which the inventory items are changed"
		},
