{
	"type": "record",
	"name": "InventoryStateChanged",
	"namespace": "net.pandora.nexus.event.inventory",
	"doc": "Event containing inventory's logical state change at a particular location. May be caused by some inventory moves. Applicable to general stock availability change in a warehouse. Use cases: stock blocked, stock unblocked, stock held for receipt, stock moved to pickable location, stock moved into inspection area, etc.",
	"fields": [
		{
			"name": "channel",
			"type": {
				"type": "enum",
				"name": "Channel",
				"namespace": "net.pandora.nexus.shared",
				"doc": "Grouping of trading places for sale of jewelry to customers and consumers based on characteristics like store ownership. E.g Non-O&O Other. All non Pandora owned and operated Stores including all Wholesales and Distributor Stores.",
				"symbols": [
					"UNKNOWN",
					"OWN_PHYSICAL",
					"OWN_ONLINE",
					"PARTNER_ONLINE",
					"FRANCHISE",
					"DISTRIBUTOR",
					"WHOLESALE",
					"OTHER_STORES",
					"PRODUCTION",
					"EMPLOYEE",
					"MARKETING",
					"PROCUREMENT",
					"FINANCE",
					"INTERCOMPANY_DISTRIBUTION",
					"WHOLESALE_EDI"
				],
				"default": "UNKNOWN"
			},
			"doc": "Grouping of trading places for sale of jewelry to customers and consumers based on characteristics like store ownership. E.g Non-O&O Other. All non Pandora owned and operated Stores including all Wholesales and Distributor Stores."
		},
		{
			"name": "id",
			"type": "string",
			"doc": "Inventory state change identifier"
		},
		{
			"name": "changeDate",
			"type": {
				"type": "long",
				"logicalType": "timestamp-millis"
			},
			"doc": "Datetime the change was initiated (in millis)"
		},
		{
			"name": "location",
			"type": {
				"type": "record",
				"name": "Location",
				"namespace": "net.pandora.nexus.shared",
				"doc": "The location where the items are physically located",
				"fields": [
					{
						"name": "id",
						"type": "string",
						"doc": "Unique location identifier"
					},
					{
						"name": "type",
						"type": {
							"type": "enum",
							"name": "LocationType",
							"doc": "Type of a location",
							"symbols": [
								"UNKNOWN",
								"WAREHOUSE",
								"STORE",
								"DARK_STORE",
								"TRANSIT",
								"PRODUCTION_SITE",
								"ZONE",
								"THIRD_PARTY_LOGISTICS",
								"DIGITAL",
								"DISTRIBUTION_GROUP"
							],
							"default": "UNKNOWN"
						},
						"doc": "Type of a location"
					}
				]
			},
			"doc": "The location where the items are physically located"
		},
		{
			"name": "entity",
			"type": [
				"null",
				"string"
			],
			"doc": "Organization code of the stock owning entity",
			"default": null
		},
		{
			"name": "type",
			"type": {
				"type": "enum",
				"name": "InventoryChangeType",
				"namespace": "net.pandora.nexus.object.inventory",
				"doc": "Change type",
				"symbols": [
					"UNKNOWN",
					"BLC",
					"CIE",
					"CIN",
					"CMD",
					"ENT",
					"MAV",
					"MIN",
