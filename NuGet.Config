<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <clear />
        <add key="Omni-integration-dev" value="https://pandora-jewelry.pkgs.visualstudio.com/0a9c6c0b-63fa-415a-8300-ded98d1fcb15/_packaging/Omni-integration-dev/nuget/v3/index.json" />
        <add key="eda-integration-platform-feed" value="https://pandora-jewelry.pkgs.visualstudio.com/eda-integration-platform/_packaging/eda-integration-platform-feed/nuget/v3/index.json" />
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    </packageSources>
    <!--
      Required once Central Package Management (Directory.Packages.props) is combined with more
      than one package source - without mapping, NuGet warns NU1507 on every restore because it
      can't tell which source should own which package id.

      Every package this solution references from nuget.org is mapped there via "*". The
      NexusFacades.* packages (inventory.InventoryStateChanged Avro consumer, see
      Directory.Packages.props) come from the internal eda-integration-platform-feed instead - do
      not widen the nuget.org "*" pattern to cover them. Omni-integration-dev remains unmapped:
      it hosts no package this solution uses today.
    -->
    <packageSourceMapping>
        <packageSource key="nuget.org">
            <package pattern="*" />
        </packageSource>
        <packageSource key="eda-integration-platform-feed">
            <package pattern="NexusFacades.*" />
        </packageSource>
    </packageSourceMapping>
</configuration>